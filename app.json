{
  "expo": {
    "name": "ThinkMoney",
    "slug": "ThinkMoney",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/logothinkmoney.png",
    "scheme": "thinkmoney",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./src/assets/images/logothinkmoney.png",
        "backgroundImage": "./src/assets/images/logothinkmoney.png",
        "monochromeImage": "./src/assets/images/logothinkmoney.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/images/logothinkmoney.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "O ThinkMoney precisa da sua localização para alertar zonas de risco financeiro próximas.",
          "locationWhenInUsePermission": "O ThinkMoney precisa da sua localização para alertar zonas de risco financeiro próximas."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./src/assets/images/logothinkmoney.png",
          "color": "#1A73E8",
          "sounds": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/logothinkmoney.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
